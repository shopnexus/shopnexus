# Non-secret runtime config for the server, as APP_* env vars (the contract the
# Go app reads via viper). Same .env syntax docker-compose uses, so this file
# doubles as documentation of the interface. Consumed by the configMapGenerator
# in kustomization.yaml. Secrets live in secret.env (git-ignored) — see README.
APP_ENV=production

# Postgres (password comes from the Secret)
APP_POSTGRES_HOST=postgres
APP_POSTGRES_PORT=5432
APP_POSTGRES_USERNAME=shopnexus
APP_POSTGRES_DATABASE=shopnexus

# Redis (password comes from the Secret)
APP_REDIS_HOST=redis
APP_REDIS_PORT=6379

# Restate <-> server wiring (in-cluster DNS; service names match compose)
APP_RESTATE_INGRESSADDRESS=http://restate:8080
APP_RESTATE_ADMINADDRESS=http://restate:9070
APP_RESTATE_SERVICEHOST=http://server
APP_RESTATE_SERVICEPORT=8082

# Embedding service (Python) — out of scope for now
APP_LLM_PYTHON_URL=http://embedding:5007

# ── Public URLs — single source of truth ────────────────────────────────────
# SITE_URL is the storefront origin, and the ONLY place the public domain lives.
#   • server:  server.yaml maps it to APP_PUBLIC_SITEURL; the app DERIVES the
#              payment return URL (…/payment/result) and SePay base from it.
#   • website: reads SITE_URL for SEO/canonical/sitemap (browser API calls are
#              same-origin /api/v1, so they need no URL config at all).
# Runtime env — change the domain here and re-sync, no rebuild.
SITE_URL=https://shop.toanehihi.io.vn

# Docs public origin. The public domain lives only here + in Caddy; the docs
# Ingress matches an internal alias (docs.internal), so this can change without
# touching any manifest.
DOCS_URL=https://docs.toanehihi.io.vn
