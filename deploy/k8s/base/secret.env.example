# TEMPLATE — copy to secret.env (git-ignored) if you enable the secretGenerator,
# or use the kubectl create secret command in README. Never commit real values.
#
# One key per secret. postgres/redis containers read their APP_* key directly
# (the image env names POSTGRES_PASSWORD / REDIS_PASSWORD are mapped from these
# in postgres.yaml / redis.yaml) — no duplicate non-APP copies.
APP_POSTGRES_PASSWORD=CHANGE_ME
APP_REDIS_PASSWORD=CHANGE_ME
APP_JWT_SECRET=CHANGE_ME
APP_EXCHANGE_APIKEY=CHANGE_ME
APP_VNPAY_TMNCODE=CHANGE_ME
APP_VNPAY_HASHSECRET=CHANGE_ME

# Optional — Grafana admin password (monitoring). Absent ⇒ Grafana admin/admin.
# GRAFANA_ADMIN_PASSWORD=CHANGE_ME
